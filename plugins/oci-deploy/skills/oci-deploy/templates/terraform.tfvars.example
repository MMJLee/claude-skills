# Copy to terraform.tfvars and fill in real values.
# Only the OCI + Cloudflare blocks are required by the bare module.
# Auth0 / GitHub / Google blocks are needed only if you include those templates.

# --- OCI Authentication ---
TENANCY_OCID         = "ocid1.tenancy.oc1..aaaa..."
USER_OCID            = "ocid1.user.oc1..aaaa..."
FINGERPRINT          = "aa:bb:cc:dd:..."
REGION               = "us-ashburn-1"
IP_ADDRESS           = "your.public.ip/32"
OCI_PRIVATE_KEY_PATH = "./oci_private_key.pem"
SSH_PUBLIC_KEY_PATH  = "./oci_public_key.pub"
SSH_PRIVATE_KEY_PATH = "./oci_private_key.pem"

# --- Cloudflare ---
CLOUDFLARE_API_TOKEN = "your-cloudflare-api-token"
CLOUDFLARE_ZONE_ID   = "your-zone-id"
DOMAIN_NAME          = "yourdomain.com"

# --- GitHub (only if using github.tf) ---
# Personal access token with `repo` scope. Terraform syncs all CI/CD secrets.
GITHUB_OWNER = "your-github-username"
GITHUB_REPO  = "your-repo"
GITHUB_TOKEN = "ghp_xxxxxxxxxxxx"

# --- Auth0 SPA app (only if using auth0.tf) ---
# Used by frontend and JWT validation in your API.
AUTH0_DOMAIN        = "yourtenant.us.auth0.com"
AUTH0_CLIENT_ID     = "your-spa-client-id"
AUTH0_CLIENT_SECRET = "your-spa-client-secret"

# --- Auth0 M2M app (only if using auth0.tf) ---
# Create in Auth0 Dashboard > Applications > Create > Machine to Machine,
# authorize for the Auth0 Management API with scopes: read:roles, create:roles,
# update:roles, read:actions, create:actions, update:actions,
# read:resource_servers, create:resource_servers, update:resource_servers,
# read:role_members, create:role_members
AUTH0_M2M_CLIENT_ID     = "your-m2m-client-id"
AUTH0_M2M_CLIENT_SECRET = "your-m2m-client-secret"

# Auth0 API identifier (audience claim) and JWT custom-claim namespace.
# JWT namespace must match what your backend reads (e.g., https://app.example.com/roles).
AUTH0_API_AUDIENCE  = "https://api.yourdomain.com"
AUTH0_JWT_NAMESPACE = "https://app.yourdomain.com"

# Allowed callback URLs for the SPA. Include local dev URLs if you log in locally.
AUTH0_CALLBACK_URLS = ["https://app.yourdomain.com", "http://localhost:5173"]

# Auto-assign admin role to one user. Find user_id at:
# Auth0 Dashboard > User Management > Users > click user > user_id.
# Leave empty to skip.
AUTH0_ADMIN_USER_ID = ""
